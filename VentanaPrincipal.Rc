 /* ============================================================
   Recurso: Icono de la aplicacion (usado en main.asm via LoadIconA, ID 200)
   ============================================================ */
200 ICON "mi_icono.ico"

/* ============================================================
   Dialogo Principal (ID 1000) - SIV
   Cargado en main.asm via CreateDialogParamA con rdx=1000
   ============================================================ */
1000 DIALOG 0, 0, 300, 180
STYLE WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "SIV - Sistema de Inventario y Ventas"
FONT 9, "MS Shell Dlg"
BEGIN
    PUSHBUTTON "Gestionar Producto",     1001, 20,  20, 120, 30
    PUSHBUTTON "Realizar Venta",         1002, 160, 20, 120, 30
    PUSHBUTTON "Consultar Inventario",   1003, 20,  70, 120, 30
    PUSHBUTTON "Reportes",               1005, 160, 70, 120, 30
END