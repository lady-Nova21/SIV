/* ============================================================
   Ventana Inventario - placeholder "Hola Mundo"
   ============================================================ */
2002 DIALOG 0, 0, 200, 100
STYLE WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "Consultar Inventario"
FONT 9, "MS Shell Dlg"
BEGIN
    LTEXT     "Hola Mundo - Inventario", -1, 20, 20, 160, 20
    PUSHBUTTON "Cerrar", 9001, 70, 60, 60, 25
END
